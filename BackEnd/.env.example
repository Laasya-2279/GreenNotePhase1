
# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Database ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/greennote

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# ── CORS / Frontend ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173